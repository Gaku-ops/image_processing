# ==========================================
# 1. OS固有のゴミファイル・言語キャッシュ
# ==========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
__pycache__/

# ==========================================
# 2. 環境設定ファイル（最重要・認証情報を含むため）
# ==========================================
.env

# ==========================================
# 3. 各コンテナの自動生成データ・ログ（先頭スラッシュ除去）
# ==========================================
# Mosquittoのデータとログ
mosquitto_data/
mosquitto_log/

# InfluxDBのデータ
influxdb3_data/

# Grafanaのデータ
grafana_data/

# ==========================================
# 4. Node-REDのキャッシュ・依存関係（強化版）
# ==========================================
nodered_data/node_modules/
nodered_data/.npm/
nodered_data/fbp-backup/
nodered_data/*.log

# 「.config」から始まるすべてのjsonファイルを除外
nodered_data/.config*.json

# すべてのバックアップファイルを除外
nodered_data/*.backup

# ==========================================
# 5. セキュリティ：Node-REDの認証情報（鉄壁版）
# ==========================================
nodered_data/flows_*cred.json
nodered_data/flows_cred.json

# ==========================================
# 6. 処理後画像
# ==========================================
shared_results/